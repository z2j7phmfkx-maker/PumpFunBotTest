        results += "━━━━━━━━━━━━━━━━━━━━\n\n"
        
        self.wins = 0
        self.losses = 0
        self.total_profit = 0
        
        for token in tokens:
            target_info = self.calculate_target_sell_price(token["entry"])
            calc = self.simulate_trade(token["entry"], token["actual_sell"], token["ath"], token["name"])
            
            if calc["profit_percent"] >= (config["profit_target"] * 100):
                self.wins += 1
            else:
                self.losses += 1
            
            self.total_profit += calc["profit_net"]
            all_trades_history.append(calc["trade_data"])
            
            results += self.format_trade_detail(token["name"], calc, target_info)
            results += f"\n🔗 <a href='{token['url']}'>Voir</a>\n"
            results += "━━━━━━━━━━━━━━━━━━━━\n\n"
        
        # Résumé
        total = self.wins + self.losses
        win_rate = (self.wins / total * 100) if total > 0 else 0
        
        results += f"<b>📊 RÉSUMÉ</b>\n\n"
        results += f"Total: {total}\n"
        results += f"✅ +{config['profit_target']*100:.0f}%: {self.wins}\n"
        results += f"❌ <{config['profit_target']*100:.0f}%: {self.losses}\n"
        results += f"Taux: {win_rate:.1f}%\n"
        results += f"\n<b>💰 Profit: {self.total_profit:.2f}€</b>"
        if total > 0:
            results += f"\nMoyen: {self.total_profit/total:.2f}€"
        
        self.save_history()
        self.send_telegram(results)
    
    def run_realtime(self):
        """Temps réel"""
        global realtime_active, all_trades_history
        
        if not wallets_to_track:
            self.send_telegram("⚠️ Ajoute un wallet")
            return
        
        tokens = self.get_real_pump_fun_tokens(wallets_to_track[0])
        
        for token in tokens:
            if not realtime_active:
                break
            
            target_info = self.calculate_target_sell_price(token["entry"])
            calc = self.simulate_trade(token["entry"], token["actual_sell"], token["ath"], token["name"])
            
            all_trades_history.append(calc["trade_data"])
            
            msg = self.format_trade_detail(token["name"], calc, target_info)
            msg += f"\n🔗 <a href='{token['url']}'>Voir</a>"
            
            self.send_telegram(msg)
            self.save_history()
            time.sleep(3)
        
        realtime_active = False
        self.send_telegram("✅ Temps réel terminé")
    
    def run(self):
        """Boucle principale"""
        global bot_running
        bot_running = True
        print("🤖 MEGA BOT FINAL activé")
        self.send_telegram("✅ MEGA BOT FINAL activé!\n\nEnvoie /start 👍")
        
        while bot_running:
            try:
                updates = self.get_updates()
                
                for update in updates:
                    self.update_offset = update.get("update_id") + 1
                    message = update.get("message", {})
                    text = message.get("text", "").strip()
                    
                    if text.startswith("/"):
                        parts = text.split()
                        command = parts[0]
                        args = parts[1:] if len(parts) > 1 else []
                        print(f"📨 Commande: {command}")
                        self.handle_command(command, args)
                
                time.sleep(1)
            
            except Exception as e:
                print(f"❌ Erreur: {e}")
                time.sleep(5)

