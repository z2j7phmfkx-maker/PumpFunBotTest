            self.send_telegram("⚠️ Ajoute un wallet d'abord (/add_wallet)")
            return
        
        # Récupère vraies données
        tokens = self.get_real_pump_fun_tokens(wallets_to_track[0])
        
        results = "📊 <b>BACKTESTING – VRAIES DONNÉES</b>\n\n"
        results += f"Wallet: <code>{wallets_to_track[0][:15]}...</code>\n"
        results += f"Tokens trouvés: {len(tokens)}\n"
        results += f"Mise: <b>{config['trade_amount']}€</b>\n"
