    def get_history_stats(self, days=None):
        """Stats historique"""
        global all_trades_history
        
        if not all_trades_history:
            return None
        
        cutoff_date = None
        if days:
            cutoff_date = (datetime.now() - timedelta(days=days)).isoformat()
        
        filtered_trades = [
            t for t in all_trades_history
            if cutoff_date is None or t.get("timestamp", "") > cutoff_date
        ]
        
        if not filtered_trades:
            return None
        
        wins = sum(1 for t in filtered_trades if t.get("is_win", False))
        losses = len(filtered_trades) - wins
        total_profit = sum(t.get("profit_net", 0) for t in filtered_trades)
        
        return {
            "trades": len(filtered_trades),
            "wins": wins,
            "losses": losses,
            "total_profit": total_profit,
            "win_rate": (wins / len(filtered_trades) * 100) if filtered_trades else 0,
            "avg_profit": total_profit / len(filtered_trades) if filtered_trades else 0
        }
    
