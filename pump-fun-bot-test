    def calculate_target_sell_price(self, entry_price):
        """Calcule prix cible pour profit target"""
        trade_amount = config["trade_amount"]
        profit_target = config["profit_target"]
        pump_fun_fee = config["pump_fun_fee"]
        solana_gas_fee = config["solana_gas_fee"]
        
        fee_achat = trade_amount * pump_fun_fee
        gas_achat = solana_gas_fee
        montant_net_achat = trade_amount - fee_achat - gas_achat
        
        montant_cible = trade_amount * (1 + profit_target)
        montant_avant_vente_cible = (montant_cible + solana_gas_fee) / (1 - pump_fun_fee)
        
        prix_vente_cible = entry_price * (montant_avant_vente_cible / montant_net_achat)
        
        return {
            "prix_vente_cible": prix_vente_cible,
            "gain_brut_necessaire": ((prix_vente_cible - entry_price) / entry_price) * 100,
            "montant_net_achat": montant_net_achat,
            "fee_achat": fee_achat,
            "gas_achat": gas_achat
        }
    
    def simulate_trade(self, entry_price, actual_sell_price, ath_price, token_name):
        """Simule une trade"""
        trade_amount = config["trade_amount"]
        profit_target = config["profit_target"]
        pump_fun_fee = config["pump_fun_fee"]
        solana_gas_fee = config["solana_gas_fee"]
        
        # ACHAT
        fee_achat = trade_amount * pump_fun_fee
        gas_achat = solana_gas_fee
        montant_net_achat = trade_amount - fee_achat - gas_achat
        
        # VENTE
        montant_avant_vente = montant_net_achat * (actual_sell_price / entry_price)
        fee_vente = montant_avant_vente * pump_fun_fee
        gas_vente = solana_gas_fee
        montant_net_vente = montant_avant_vente - fee_vente - gas_vente
        
        # PROFITS
        profit_net = montant_net_vente - trade_amount
        profit_percent = (profit_net / trade_amount) * 100
        gain_brut_token = ((actual_sell_price - entry_price) / entry_price) * 100
        ath_gain = ((ath_price - entry_price) / entry_price) * 100
        
        trade_data = {
            "timestamp": datetime.now().isoformat(),
            "token_name": token_name,
            "entry_price": entry_price,
            "sell_price": actual_sell_price,
            "ath_price": ath_price,
            "profit_net": profit_net,
            "profit_percent": profit_percent,
            "gain_brut_token": gain_brut_token,
            "ath_gain": ath_gain,
            "is_win": profit_percent >= (profit_target * 100),
            "wallet": wallets_to_track[0] if wallets_to_track else "unknown",
            "config": config.copy()
        }
        
        return {
            "entry_price": entry_price,
            "sell_price": actual_sell_price,
            "ath_price": ath_price,
            "fee_achat": fee_achat,
            "gas_achat": gas_achat,
            "montant_net_achat": montant_net_achat,
            "montant_avant_vente": montant_avant_vente,
            "fee_vente": fee_vente,
            "gas_vente": gas_vente,
            "montant_net_vente": montant_net_vente,
            "profit_net": profit_net,
            "profit_percent": profit_percent,
            "gain_brut_token": gain_brut_token,
            "ath_gain": ath_gain,
            "token_name": token_name,
            "trade_data": trade_data
        }
    
